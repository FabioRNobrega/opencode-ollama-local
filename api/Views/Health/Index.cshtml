@model Api.Models.HealthViewModel
@{
    ViewData["Title"] = "Health";
}

<section class="card bg-base-100 shadow-2xl">
    <div class="card-body gap-6">
        <div>
            <h1 class="card-title text-3xl font-bold">Service Health</h1>
            <p class="text-base-content/70">System status for this API instance</p>
        </div>

        <div class="stats stats-vertical shadow sm:stats-horizontal">
            <div class="stat">
                <div class="stat-title">OK</div>
                <div class="stat-value @(Model.Ok ? "text-success" : "text-error")">
                    @Model.Ok.ToString().ToLowerInvariant()
                </div>
            </div>
            <div class="stat">
                <div class="stat-title">Status</div>
                <div class="stat-value text-lg sm:text-2xl">@Model.Status</div>
            </div>
            <div class="stat">
                <div class="stat-title">Time (UTC)</div>
                <div class="stat-value text-lg sm:text-2xl">@Model.Time.ToString("u")</div>
            </div>
        </div>

        <div class="card-actions justify-end">
            <a href="/" class="btn btn-outline btn-sm">Back Home</a>
        </div>
    </div>
</section>
