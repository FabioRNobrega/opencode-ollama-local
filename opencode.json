{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3.5:0.8b",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (docker)",
      "options": {
        "baseURL": "http://ollama:11434/v1"
      },
      "models": {
        "qwen3.5:0.8b": {
          "name": "Qwen3.5 Coder"
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "rm *": "deny",
      "sudo *": "deny"
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".vs/**",
      "api/bin/**",
      "api/obj/**"
    ]
  }
}